# ── Dependências ─────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Build ─────────────────────────────────────────────────
frontend/dist/

# ── Banco de dados (não versionar dados pessoais) ─────────
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# ── Arquivos enviados pelos usuários ──────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Design concepts (protótipos, não necessários em prod) ─
design-concepts/

# ── Imagens de desenvolvimento/referência ─────────────────
frontend/*.png
frontend/*.jpg

# ── Variáveis de ambiente ─────────────────────────────────
.env
.env.local
.env.production

# ── Sistema operacional ───────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
